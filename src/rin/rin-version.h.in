#ifndef RIN_VERSION_H
#define RIN_VERSION_H 1

#if !defined(RIN_INSIDE) && !defined(RIN_COMPILATION)
# error "Only <rin.h> can be included directly."
#endif

/**
 * SECTION:rinversion
 * @short_description: rin version checking
 *
 * rin provides macros to check the version of the library
 * at compile-time
 */

/**
 * RIN_MAJOR_VERSION:
 *
 * rin major version component (e.g. 1 if %RIN_VERSION is 1.2.3)
 */
#define RIN_MAJOR_VERSION (@MAJOR_VERSION@)

/**
 * RIN_MINOR_VERSION:
 *
 * rin minor version component (e.g. 2 if %RIN_VERSION is 1.2.3)
 */
#define RIN_MINOR_VERSION (@MINOR_VERSION@)

/**
 * RIN_MICRO_VERSION:
 *
 * rin micro version component (e.g. 3 if %RIN_VERSION is 1.2.3)
 */
#define RIN_MICRO_VERSION (@MICRO_VERSION@)

/**
 * RIN_VERSION
 *
 * rin version.
 */
#define RIN_VERSION (@VERSION@)

/**
 * RIN_VERSION_S:
 *
 * rin version, encoded as a string, useful for printing and
 * concatenation.
 */
#define RIN_VERSION_S "@VERSION@"

#define RIN_ENCODE_VERSION(major,minor,micro) \
        ((major) << 24 | (minor) << 16 | (micro) << 8)

/**
 * RIN_VERSION_HEX:
 *
 * rin version, encoded as an hexadecimal number, useful for
 * integer comparisons.
 */
#define RIN_VERSION_HEX \
        (RIN_ENCODE_VERSION (RIN_MAJOR_VERSION, RIN_MINOR_VERSION, RIN_MICRO_VERSION))

/**
 * RIN_CHECK_VERSION:
 * @major: required major version
 * @minor: required minor version
 * @micro: required micro version
 *
 * Compile-time version checking. Evaluates to %TRUE if the version
 * of rin is greater than the required one.
 */
#define RIN_CHECK_VERSION(major,minor,micro)   \
        (RIN_MAJOR_VERSION > (major) || \
         (RIN_MAJOR_VERSION == (major) && RIN_MINOR_VERSION > (minor)) || \
         (RIN_MAJOR_VERSION == (major) && RIN_MINOR_VERSION == (minor) && \
          RIN_MICRO_VERSION >= (micro)))

#endif /* RIN_VERSION_H */
